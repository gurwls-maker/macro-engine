{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/tools/render_audit/run_product_preflight.cjs\" --context",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; node (Join-Path $root 'tools/render_audit/run_product_preflight.cjs') --context\"",
            "timeout": 30,
            "statusMessage": "Loading macro-engine product guard"
          }
        ]
      }
    ]
  }
}

